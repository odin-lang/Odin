	.F32X4_SPLAT                         = {prefix = PREFIX_SIMD, opcode = 0x13},
	.F64X2_SPLAT                         = {prefix = PREFIX_SIMD, opcode = 0x14},
	.I8X16_EXTRACT_LANE_S                = {prefix = PREFIX_SIMD, opcode = 0x15, imm = {.LANE, .NONE}},
