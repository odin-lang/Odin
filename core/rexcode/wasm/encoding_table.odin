	.I64X2_EXTRACT_LANE                  = {prefix = PREFIX_SIMD, opcode = 0x1D, imm = {.LANE, .NONE}},
	.I64X2_REPLACE_LANE                  = {prefix = PREFIX_SIMD, opcode = 0x1E, imm = {.LANE, .NONE}},
	.F32X4_EXTRACT_LANE                  = {prefix = PREFIX_SIMD, opcode = 0x1F, imm = {.LANE, .NONE}},
